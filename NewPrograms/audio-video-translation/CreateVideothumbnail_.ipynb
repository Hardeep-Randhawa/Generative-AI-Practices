    {
      "cell_type": "code",
      "source": [
        "import cv2\n",
        "import torch\n",
        "from PIL import Image\n",
        "import yt_dlp\n",
        "from transformers import MllamaForConditionalGeneration, MllamaProcessor\n",
        "from google.colab import files\n",
        "from huggingface_hub import login\n",
        "from IPython.display import display"
      ],
      "metadata": {
        "id": "DqiAbY_siWJP"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "\n",
        "login("")\n",
        "\n",
        "def get_video_stream_path(video_input: str) -> str:\n",
        "    \"\"\"\n",
        "    Checks if the input string is a YouTube URL.\n",
        "    If true, extracts and returns the direct streaming URL via yt-dlp.\n",
        "    Otherwise, returns the original local path string.\n",
        "    \"\"\"\n",
        "    if \"youtube.com\" in video_input or \"youtu.be\" in video_input:\n",
        "        print(\"📺 YouTube link detected. Extracting direct stream URL...\")\n",
        "        ydl_opts = {\n",
        "            'format': 'bestvideo[ext=mp4]/mp4',\n",
        "            'quiet': True,\n",
        "            'no_warnings': True\n",
        "        }\n",
        "        with yt_dlp.YoutubeDL(ydl_opts) as ydl:\n",
        "            info = ydl.extract_info(video_input, download=False)\n",
        "            return info['url']\n",
        "    else:\n",
        "        print(\"📂 Local path detected. Proceeding with file path...\")\n",
        "        return video_input\n",
        "\n",
        "def extract_candidate_frames(video_input: str, num_candidates: int = 3) -> dict:\n",
        "    \"\"\"Extracts evenly spaced frames from a local video file or a YouTube stream link.\"\"\"\n",
        "    resolved_path = get_video_stream_path(video_input)\n",
        "\n",
        "    cap = cv2.VideoCapture(resolved_path)\n",
        "    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n",
        "    fps = cap.get(cv2.CAP_PROP_FPS)\n",
        "\n",
        "    # Workaround fallback if stream metadata doesn't initially expose a total frame count\n",
        "    if total_frames <= 0:\n",
        "        total_frames = int(fps * 45) if fps > 0 else 1200\n",
        "\n",
        "    interval = total_frames // (num_candidates + 1)\n",
        "    candidates = {}\n",
        "\n",
        "    for i in range(1, num_candidates + 1):\n",
        "        frame_idx = i * interval\n",
        "        cap.set(cv2.CAP_PROP_POS_FRAMES, frame_idx)\n",
        "        ret, frame = cap.read()\n",
        "        if ret:\n",
        "            # Convert OpenCV BGR channel mapping to standard PIL RGB format\n",
        "            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n",
        "            pil_img = Image.fromarray(rgb_frame)\n",
        "            candidates[i] = {\"image\": pil_img, \"frame_idx\": frame_idx}\n",
        "        else:\n",
        "            print(f\"⚠️ Unable to parse frames around position index: {frame_idx}\")\n",
        "\n",
        "    cap.release()\n",
        "\n",
        "    if not candidates:\n",
        "        raise ValueError(\"Could not successfully capture any target video frames.\")\n",
        "\n",
        "    return candidates\n",
        "\n",
        "def pick_best_thumbnail_with_llama(video_path: str):\n",
        "    # 1. Trigger the user authentication prompt for HuggingFace Hub access\n",
        "    print(\"--- Hugging Face Authentication ---\")\n",
        "    login()\n",
        "\n",
        "    # 2. Slice candidates from the source video path\n",
        "    candidates = extract_candidate_frames(video_path, num_candidates=3)\n",
        "\n",
        "    # 3. Load Llama 3.2 Vision Model weights onto the T4 GPU\n",
        "    print(\"\\n🚀 Initializing Meta-Llama-3.2-11B-Vision-Instruct...\")\n",
        "    model_id = \"meta-llama/Llama-3.2-11B-Vision-Instruct\"\n",
        "\n",
        "    model = MllamaForConditionalGeneration.from_pretrained(\n",
        "        model_id,\n",
        "        torch_dtype=torch.bfloat16,   # Fits cleanly into Colab T4's 16GB VRAM bounds\n",
        "        device_map=\"auto\"\n",
        "    )\n",
        "    processor = MllamaProcessor.from_pretrained(model_id)\n",
        "\n",
        "    # 4. Prompt structuring engineering for Visual Context evaluation\n",
        "    prompt_text = (\n",
        "        \"You are an expert YouTube thumbnail designer. Look at these 3 frames sampled from a video. \"\n",
        "        \"Analyze their lighting, composition, and subject matter. Tell me which frame (1, 2, or 3) \"\n",
        "        \"would make the most compelling, high-click-through-rate thumbnail. \"\n",
        "        \"Start your response strictly with: 'CHOSEN FRAME: [Number]' followed by a brief 2-sentence explanation.\"\n",
        "    )\n",
        "\n",
        "    conversation = [\n",
        "        {\n",
        "            \"role\": \"user\",\n",
        "            \"content\": [\n",
        "                {\"type\": \"image\"}, # Frame 1\n",
        "                {\"type\": \"image\"}, # Frame 2\n",
        "                {\"type\": \"image\"}, # Frame 3\n",
        "                {\"type\": \"text\", \"text\": prompt_text}\n",
        "            ]\n",
        "        }\n",
        "    ]\n",
        "\n",
        "    images = [candidates[1][\"image\"], candidates[2][\"image\"], candidates[3][\"image\"]]\n",
        "    prompt = processor.apply_chat_template(conversation, add_generation_prompt=True, tokenize=False)\n",
        "    inputs = processor(prompt, images, return_tensors=\"pt\").to(model.device)\n",
        "\n",
        "    print(\"🧠 Llama is evaluating visual features and CTR potential...\")\n",
        "    output = model.generate(**inputs, max_new_tokens=150)\n",
        "    response = processor.decode(output[0])[len(prompt):]\n",
        "\n",
        "    print(\"\\n🎬 --- Llama's Editorial Decision ---\")\n",
        "    print(response.strip())\n",
        "\n",
        "    # 5. Extract structural selection numerical identity value\n",
        "    chosen_idx = 1\n",
        "    for num in [\"1\", \"2\", \"3\"]:\n",
        "        if f\"CHOSEN FRAME: {num}\" in response or f\"FRAME: {num}\" in response:\n",
        "            chosen_idx = int(num)\n",
        "            break\n",
        "\n",
        "    # 6. Isolate and cache selected image asset path output\n",
        "    final_thumbnail = candidates[chosen_idx][\"image\"]\n",
        "    output_filename = \"chosen_thumbnail.png\"\n",
        "    final_thumbnail.save(output_filename)\n",
        "    print(f\"\\n✨ Successfully captured and saved Frame {chosen_idx} as '{output_filename}'!\")\n",
        "\n",
        "    print(\"\\n--- Displaying Selection ---\")\n",
        "    display(final_thumbnail)\n",
        "    return final_thumbnail\n",
        "\n",
        "# --- Execution Entry Point ---\n",
        "if __name__ == \"__main__\":\n",
        "    # You can alternate this directly with a local file path (e.g. \"my_video.mp4\")\n",
        "    # or keep a YouTube URL string here.\n",
        "\n",
        "    target_video_path = \"/content/sample_data/14351124_3840_2160_60fps.mp4\"\n",
        "\n",
        "    # Run the full automation stack\n",
        "    best_frame = pick_best_thumbnail_with_llama(target_video_path)"
      ],
